            "type": "object",
            "description": "ISO date string."
          },
          "minSubtotal": {
            "type": "object",
            "description": "Minimum subtotal in cents."
          },
          "usageLimit": {
            "type": "object"
          }
        }
      },
      "AddItemDto": {
        "type": "object",
        "properties": {}
      },
      "UpdateItemDto": {
        "type": "object",
        "properties": {}
      },
      "ApplyCouponDto": {
        "type": "object",
        "properties": {}
      },
      "AddressDto": {
        "type": "object",
        "properties": {}
      },
      "CheckoutDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "buyer@example.com"
          },
          "billingAddress": {
            "$ref": "#/components/schemas/AddressDto"
          }
        },
        "required": [
          "email"
        ]
      },
      "UpdateOrderStatusDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "PAID",
              "FULFILLED",
              "CANCELLED",
              "REFUNDED"
            ]
          }
        },
        "required": [
          "status"
        ]
      }
    }
