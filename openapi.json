  "info": {
    "title": "Nexlor Commerce API",
    "description": "Storefront + Admin API for the Nexlor commerce template.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "UpdateSettingsDto": {
        "type": "object",
        "properties": {}
      },
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "jane@example.com"
          },
          "name": {
            "type": "string",
            "example": "Jane Doe"
          },
          "password": {
            "type": "string",
            "example": "Password123!",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "name",
          "password"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "customer@nexlor.test"
          },
          "password": {
            "type": "string",
            "example": "Password123!"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "VariantInputDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "priceOverride": {
            "type": "object",
            "description": "Override price in cents; null = use basePrice."
          }
        }
      },
      "ImageInputDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        }
      },
      "CreateProductDto": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "URL slug; auto-generated from name if omitted."
          },
          "basePrice": {
            "type": "number",
            "description": "Base price in cents."
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "ACTIVE",
              "ARCHIVED"
            ],
            "default": "DRAFT"
          },
          "categoryIds": {
            "description": "Category ids.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VariantInputDto"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageInputDto"
            }
          }
        }
      },
      "UpdateProductDto": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string",
            "description": "URL slug; auto-generated from name if omitted."
          },
          "basePrice": {
            "type": "number",
            "description": "Base price in cents."
          },
          "status": {
            "type": "string",
            "enum": [
              "DRAFT",
              "ACTIVE",
              "ARCHIVED"
            ],
            "default": "DRAFT"
          },
          "categoryIds": {
            "description": "Category ids.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/VariantInputDto"
            }
          },
          "images": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImageInputDto"
            }
          }
        }
      },
      "BulkStatusDto": {
        "type": "object",
        "properties": {}
      },
      "ReorderImagesDto": {
        "type": "object",
        "properties": {}
      },
      "CreateCategoryDto": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "parentId": {
            "type": "object",
            "description": "Parent category id for nesting."
          },
          "position": {
            "type": "number"
          }
        }
      },
      "UpdateCategoryDto": {
        "type": "object",
        "properties": {
          "slug": {
            "type": "string"
          },
          "parentId": {
            "type": "object",
            "description": "Parent category id for nesting."
          },
          "position": {
            "type": "number"
          }
        }
      },
      "PresignDto": {
        "type": "object",
        "properties": {
          "filename": {
            "type": "string",
            "example": "hero-shot.jpg"
          },
          "contentType": {
            "type": "string",
            "example": "image/jpeg"
          }
        },
        "required": [
          "filename",
          "contentType"
        ]
      },
      "ValidateCouponDto": {
        "type": "object",
        "properties": {}
      },
      "CreateCouponDto": {
        "type": "object",
        "properties": {
          "value": {
            "type": "number",
            "description": "PERCENT: 0–100. FIXED: cents."
          },
          "active": {
            "type": "boolean",
            "default": true
          },
          "expiresAt": {
            "type": "object",
            "description": "ISO date string."
          },
          "minSubtotal": {
            "type": "object",
            "description": "Minimum subtotal in cents."
          },
          "usageLimit": {
            "type": "object"
          }
        }
      },
      "UpdateCouponDto": {
        "type": "object",
