# ----- Core -----
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed browser origins (storefront + admin).
# In production set this to your deployed frontend URLs, e.g.:
#   CORS_ORIGINS=https://your-storefront.vercel.app,https://your-admin.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ----- Database -----
# Matches docker-compose.yml (default port 5432). If 5432 is already in use on
# your machine, set DB_PORT in the ROOT .env (e.g. DB_PORT=5544) and change the
# port below to match — docker-compose maps "${DB_PORT:-5432}:5432".
# In production (Render) this is auto-injected from the managed Postgres; an
# external connection string must include ?sslmode=require.
DATABASE_URL=postgresql://nexlor:nexlor@localhost:5432/nexlor_commerce?schema=public

# ----- Auth (JWT access + refresh) -----
# Use long random strings in production: `openssl rand -base64 48`
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL=900            # seconds (15m)
JWT_REFRESH_TTL=2592000       # seconds (30d)
# ----- Cookies -----
# Local dev (same-site http://localhost): keep the defaults below.
# Cross-site production (frontend on Vercel, API on Render — different domains):
#   COOKIE_DOMAIN=          (empty: host-only cookie on the API domain)
#   COOKIE_SECURE=true      (required by SameSite=None; API is served over HTTPS)
#   COOKIE_SAMESITE=none    (so the browser sends cookies on cross-site requests)
# NOTE: Safari/iOS block third-party cookies, so cross-site auth may fail there.
# Put the frontend and API on subdomains of ONE domain to avoid that (see DEPLOY.md).
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ----- Cloudflare R2 (S3-compatible) — product image uploads -----
# Leave blank to disable uploads (presign endpoint returns 503). Swap-friendly.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=nexlor-commerce
# Public base URL where the bucket is served (CDN/custom domain).
R2_PUBLIC_BASE_URL=https://cdn.example.com
# Endpoint is derived from R2_ACCOUNT_ID; override only for non-R2 S3.
R2_ENDPOINT=
