// Nexlor Commerce — data model.
//
// MONEY: every monetary field is an Int representing the smallest currency unit
// (cents). e.g. $19.99 is stored as 1999. NEVER use Float/Decimal for money —
// floats lose precision. Totals are always recomputed server-side at checkout.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums — mirrored verbatim in frontend/packages/types. Keep them identical.
// ---------------------------------------------------------------------------

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  FULFILLED
  CANCELLED
  REFUNDED
}

enum CouponType {
  PERCENT // value = basis percent, 0–100
  FIXED // value = fixed amount in cents
}

// ---------------------------------------------------------------------------
// Identity & auth
// ---------------------------------------------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens RefreshToken[]
  addresses     Address[]
  orders        Order[]
  cart          Cart?

  @@index([role])
}

// Refresh-token rotation: each issued refresh token is hashed and stored.
// On refresh we verify + revoke the old one and issue a new row.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String? // "Home", "Work"
  fullName   String
  line1      String
  line2      String?
  city       String
  region     String? // state / province
  postalCode String
  country    String // ISO-3166 alpha-2
  phone      String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Catalog
// ---------------------------------------------------------------------------

model Product {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        String
  description String        @db.Text
  basePrice   Int // cents — default price; variants may override
  status      ProductStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  variants   ProductVariant[]
  images     ProductImage[]
  categories ProductCategory[]

  // Hot path: storefront lists ACTIVE products newest-first.
  @@index([status, createdAt])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku           String   @unique
  name          String // "Small / Black", or "Default"
  priceOverride Int? // cents; falls back to product.basePrice when null
  stock         Int      @default(0)
  position      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartItems CartItem[]

  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String  @default("")
  position  Int     @default(0)

  @@index([productId])
}

model Category {
  id       String     @id @default(cuid())
  slug     String     @unique
  name     String
  parentId String?
  // Self-relation for nesting.
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")
  position Int        @default(0)

  products ProductCategory[]

  @@index([parentId])
}

// Explicit m:n join so we can add ordering/metadata later.
model ProductCategory {
  productId  String
  categoryId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Cart — guest carts keyed by httpOnly session cookie; merged on login.
// ---------------------------------------------------------------------------

model Cart {
  id         String   @id @default(cuid())
  // Exactly one of (sessionId, userId) identifies the cart owner.
  sessionId  String?  @unique
  userId     String?  @unique
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Applied coupon code (validated again at checkout — never trusted blindly).
  couponCode String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items CartItem[]
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
}

// ---------------------------------------------------------------------------
// Orders — OrderItem stores a snapshot of product data at purchase time so
// later catalog edits never rewrite history.
// ---------------------------------------------------------------------------

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // human-readable, e.g. NEX-7F3K2Q
  userId      String? // null for guest checkout
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String
  status      OrderStatus @default(PENDING)

  // All amounts in cents. total = subtotal - discount + shipping + tax.
  subtotal Int
  discount Int    @default(0)
  shipping Int    @default(0)
  tax      Int    @default(0)
  total    Int
  currency String @default("USD")

  couponCode String?

  shippingAddress Json // snapshot, not an FK — addresses can change/delete
  billingAddress  Json?

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Hot paths: a customer's order history, and admin status filtering.
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Snapshot fields — intentionally denormalized.
  variantId   String? // soft reference for analytics; may be null if deleted
  productName String
  variantName String
  sku         String
  unitPrice   Int // cents at purchase time
  quantity    Int
  lineTotal   Int // unitPrice * quantity
  imageUrl    String?

  @@index([orderId])
  @@index([variantId])
}

// ---------------------------------------------------------------------------
// Promotions
// ---------------------------------------------------------------------------

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        CouponType
  value       Int // PERCENT: 0–100 ; FIXED: cents
  active      Boolean    @default(true)
  expiresAt   DateTime?
  minSubtotal Int? // cents threshold
  usageLimit  Int? // null = unlimited
  usedCount   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([active])
}

// ---------------------------------------------------------------------------
// Store configuration — key/value Json so the template is configurable per
// client without code changes (branding, currency, tax rate, shipping rules).
// ---------------------------------------------------------------------------

model StoreSetting {
  key       String   @id // e.g. "branding", "commerce", "shipping"
  value     Json
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Variant Presets — reusable option sets (e.g. "Size", "Color") that can be
// applied when creating new products, speeding up catalog management.
// ---------------------------------------------------------------------------

model VariantPreset {
  id        String   @id @default(cuid())
  name      String   @unique
  options   String[]
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
